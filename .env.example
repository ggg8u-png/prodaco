# 분석/색인
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# 네이버 서치어드바이저 소유확인 코드. 비워두면 layout.tsx의 기본값이 출력됨. 재인증 시 새 코드로 설정.
NEXT_PUBLIC_NAVER_VERIFY=

# 상담 채널
NEXT_PUBLIC_KAKAO_CHANNEL_URL=https://open.kakao.com/o/sUneW8Xg

# 운영 도메인 (canonical/sitemap/JSON-LD 기준 — 실제 도메인으로 설정)
NEXT_PUBLIC_SITE_URL=https://prodaco.kr

# 네이버 플레이스 URL (있을 때만 관련 CTA 노출). 없으면 비워둠
NEXT_PUBLIC_NAVER_PLACE_URL=

# 응대 안내 문구 (보장 표현 금지 — 안내 톤만). 예: "영업시간 내 빠르게 답변드립니다"
NEXT_PUBLIC_RESPONSE_TIME_TEXT=

# 빌드 시 생성할 키워드 페이지 총 개수 ("숫자만 바꾸면 그만큼 생성").
#  - 미설정/0 → 큐레이션 라이브(keywords.json)만 생성 = 현행 동작(가장 안전).
#  - 늘리면 staging 우선순위 순으로 추가 생성되며, 추가분은 기본 noindex(canonical은 상위 지역+품목).
#  - 라이브 수 미만으로 설정해도 라이브 전체는 항상 생성됩니다(검수 페이지 보호).
#  Netlify 에서는 이 값을 UI 환경변수로 설정 → Trigger deploy. (자세히는 STAGED_KEYWORDS_GUIDE.md)
GENERATE_COUNT=
